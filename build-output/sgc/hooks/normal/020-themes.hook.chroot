#!/bin/bash
set -e

echo "Downloading SGC Plymouth theme"
wget -q https://kazam.pages.dev/public/dec.1/sgc_plymouth.7z
p7zip -d sgc_plymouth.7z
cp -r sgc /usr/share/plymouth/themes/
plymouth-set-default-theme sgc --rebuild-initrd

rm -rf /sgc*

apt install kos-theme kos-kvantum-theme tela-circle-manjaro-icons kos-sounds -y
