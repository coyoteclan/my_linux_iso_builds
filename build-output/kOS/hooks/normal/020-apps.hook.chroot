#!/bin/bash
set -e

#@WINE

#echo "Installing KDENLIVE"
#am install kdenlive > /dev/null 2>&1
#echo "KDENLIVE Installed"

am install baobab

echo "Installing Discord"
# am install discord > /dev/null 2>&1
wget "https://discord.com/api/download?platform=linux&format=deb" -O discord.deb
apt install -y ./discord.deb
rm discord.deb
echo "Discord Installed"

echo "Adding wine repo"
mkdir -pm755 /etc/apt/keyrings
wget -O - https://dl.winehq.org/wine-builds/winehq.key | gpg --dearmor -o /etc/apt/keyrings/winehq-archive.key -
dpkg --add-architecture i386
wget -NP /etc/apt/sources.list.d/ https://dl.winehq.org/wine-builds/ubuntu/dists/resolute/winehq-resolute.sources

echo "Adding vscodium repo"
wget -qO - https://gitlab.com/paulcarroty/vscodium-deb-rpm-repo/raw/master/pub.gpg \
  | gpg --dearmor \
  | dd of=/etc/apt/keyrings/vscodium-archive-keyring.gpg

cat > /etc/apt/sources.list.d/vscodium.sources << 'EOF'
Types: deb
URIs: https://download.vscodium.com/debs
Suites: vscodium
Components: main
Architectures: amd64 arm64
Signed-by: /etc/apt/keyrings/vscodium-archive-keyring.gpg

EOF

echo "Adding media-downloader repo"
echo 'deb http://download.opensuse.org/repositories/home:/obs_mhogomchungu/xUbuntu_25.10/ /' | sudo tee /etc/apt/sources.list.d/home:obs_mhogomchungu.list
curl -fsSL https://download.opensuse.org/repositories/home:obs_mhogomchungu/xUbuntu_25.10/Release.key | gpg --dearmor | sudo tee /etc/apt/trusted.gpg.d/home_obs_mhogomchungu.gpg > /dev/null

echo "Adding brave repo"
curl -fsSLo /usr/share/keyrings/brave-browser-archive-keyring.gpg https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg
curl -fsSLo /etc/apt/sources.list.d/brave-browser-release.sources https://brave-browser-apt-release.s3.brave.com/brave-browser.sources

echo "Adding firefox repo"
curl -fsSL https://packages.mozilla.org/apt/repo-signing-key.gpg | gpg --dearmor -o /etc/apt/keyrings/mozilla.gpg
echo "deb [signed-by=/etc/apt/keyrings/mozilla.gpg] https://packages.mozilla.org/apt mozilla main" > /etc/apt/sources.list.d/mozilla.list

#echo "Enabling librewolf repo with extrepo"
# extrepo enable librewolf && extrepo update librewolf

apt update
apt install -t voltage calamares calamares-settings-kos xournalpp -y
apt-mark hold calamares calamares-data libcalamares3.3 libcalamaresui3.3 snapd

apt install kazamos-desktop-base donatepage rustdesk supertuxkart-mini termom -y
apt install -t mozilla firefox -y

cp /etc/skel/.face /home/user/
(cd /home/user;ln -sf .face .face.icon;chown -R user:user .face*)
apt install libgl1:i386 libgl1-mesa-dri:i386 -y
apt install -y unar --no-install-recommends

if [ "$WINE" = "yes" ]; then
   apt install --install-recommends winehq-stable -y
   apt install --no-install-recommends winetricks -y
fi

echo "############ running apt autoreomve"
apt autoremove -y


sudo update-desktop-database /usr/share/applications 2>/dev/null || true

# Write system-wide MIME association instead of user-level
MIMEAPPS=/usr/share/applications/mimeapps.list

if ! grep -q '\[Default Applications\]' "$MIMEAPPS" 2>/dev/null; then
    echo '[Default Applications]' | sudo tee -a "$MIMEAPPS" > /dev/null
fi

# Add or replace the handler entry
if grep -q 'x-scheme-handler/donatepage' "$MIMEAPPS"; then
    sudo sed -i 's|^x-scheme-handler/donatepage=.*|x-scheme-handler/donatepage=donatepage.desktop|' "$MIMEAPPS"
else
    sudo sed -i '/\[Default Applications\]/a x-scheme-handler/donatepage=donatepage.desktop' "$MIMEAPPS"
fi

sudo update-desktop-database /usr/share/applications 2>/dev/null || true
sudo gtk-update-icon-cache /usr/share/icons/hicolor
