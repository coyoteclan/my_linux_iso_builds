#!/bin/bash
set -e

wget -q https://raw.githubusercontent.com/Keyitdev/sddm-astronaut-theme/refs/heads/master/Backgrounds/purple_leaves.png -O /usr/share/backgrounds/purple_leaves.png

# Hack - Since I can't get the wallpaper to apply
echo "Wallpaper hack"
mv /usr/share/backgrounds/xfce/xfce-x.svg /usr/share/backgrounds/xfce/xfce-x_original.svg
ln -s /usr/share/backgrounds/purple_leaves.png /usr/share/backgrounds/xfce/xfce-x.svg

echo "Downloading includes"
wget -q https://kazam.pages.dev/public/mar.12.26/desktop_includes.7z
p7zip -d desktop_includes.7z
cp -r desktop_includes/* /etc/skel/
ls /etc/skel
cp -r /etc/skel/* /home/user/
chown -R user:user /home/user/*

rm -rf desktop_includes*

sed -i 's/#ur_PK/ur_PK/g' /etc/locale.gen
sed -i 's/# ur_PK/ur_PK/g' /etc/locale.gen
locale-gen
update-locale

sed -i 's|Urdu Nastaliq Unicode|PakType Naskh Basic|g' /usr/share/fontconfig/conf.avail/65-nonlatin.conf

systemctl enable first-boot-exec.service
systemctl disable systemd-networkd || echo "##### Failed to disable systemd-networkd"

sed -i 's/Hidden=true/Hidden=false/' /etc/xdg/autostart/xfce4-clipman-plugin-autostart.desktop

cat /etc/os-release

mv /etc/os-release /etc/os-release-ubuntu

cat > /etc/os-release << 'EOF'
PRETTY_NAME="kazamOS 2.0 (voltage)"
NAME="kazamOS"
VERSION_ID="2"
VERSION="2 (voltage)"
VERSION_CODENAME=voltage
ID="kazamos"
LOGO="kazamos-short"
ID_LIKE="ubuntu debian"
UBUNTU_CODENAME=resolute
HOME_URL="https://kazamOS.gitlab.io/"
SUPPORT_URL="https://matrix.to/#/#kazamos:matrix.org/"
BUG_REPORT_URL="https://gitlab.com/kazamOS/"

EOF

cat /etc/os-release
