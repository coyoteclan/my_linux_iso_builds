#!/bin/bash

echo "Running first boot script"

# Update GTK / icon caches
for d in /usr/share/icons/* /usr/local/share/icons/*; do
  if [ -f "$d/index.theme" ]; then
    gtk-update-icon-cache -f -t "$d"
  fi
done
gtk-update-icon-cache -f -t /usr/share/icons/hicolor

# after install /opt/am becomes read-only
chmod -R 757 /opt/am

# fix netplan not allowing network manager to manager network on ubuntu
mkdir -p /etc/netplan
cat /etc/netplan/01-network-manager-all.yaml << 'EOF'
network:
  version: 2
  renderer: NetworkManager
  ethernets:
    all-eth:
      match:
        name: "en*"
      dhcp4: true
  wifis:
    all-wifi:
      match:
        name: "wl*"
      dhcp4: true

EOF

chown root:root /etc/netplan/01-network-manager-all.yaml
chmod 600 /etc/netplan/01-network-manager-all.yaml

netplan generate
systemctl restart NetworkManager

# local repo with bootloader packages
if ! loginctl list-users | grep -qw user; then
    rm -f /etc/apt/sources.list.d/local.list
    rm -rf /opt/repo
    apt update
fi

systemctl disable first-boot-exec.service || true
rm /etc/systemd/system/first-boot-exec.service
rm /usr/local/bin/first-boot-exec
