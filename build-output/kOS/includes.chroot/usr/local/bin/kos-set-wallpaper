#!/bin/bash
# Only run once
FLAG="$HOME/.config/kos-wallpaper-set"
[ -f "$FLAG" ] && exit 0

WALLPAPER="/usr/share/backgrounds/purple_leaves.png"

for monitor in $(xfconf-query -c xfce4-desktop -l | grep "last-image"); do
    xfconf-query -c xfce4-desktop -p "$monitor" -s "$WALLPAPER"
done

touch "$FLAG"
xfdesktop --reload &
